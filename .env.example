# Local development defaults. Do not commit real secrets.
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

PARKING_PROVIDER_MODE=mock
DEFAULT_SEARCH_RADIUS_METERS=800
DEFAULT_DISCOVER_RADIUS_METERS=20000
STALE_THRESHOLD_SECONDS=600
CACHE_TTL_SECONDS=60
DISCOVER_CACHE_TTL_SECONDS=21600

FESTIVAL_PROVIDER_ENABLED=true
EVENT_PROVIDER_ENABLED=true
LOCAL_EVENT_PROVIDER_ENABLED=true
LOCAL_EVENT_AUTO_APPROVE_MIN_SCORE=0.80
LOCAL_EVENT_SEARCH_MAX_QUERIES=360
KAKAO_CATEGORY_RADIUS_METERS=1500

NAVER_CLIENT_ID=your_naver_search_client_id
NAVER_CLIENT_SECRET=your_naver_search_client_secret
NAVER_SEARCH_BASE_URL=https://openapi.naver.com

KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com

SEOUL_OPEN_DATA_KEY=your_seoul_open_data_key
SEOUL_OPEN_DATA_BASE_URL=http://openapi.seoul.go.kr:8088
SEOUL_SEONGDONG_IOT_KEY=your_seoul_seongdong_iot_key
SEOUL_HANGANG_PARKING_KEY=your_seoul_hangang_parking_key

PUBLIC_DATA_SERVICE_KEY=your_data_go_kr_service_key
PUBLIC_DATA_ENV=development
PUBLIC_DATA_BASE_URL=https://apis.data.go.kr
TOUR_FESTIVAL_MAX_PAGES=20
NATIONAL_CULTURE_MAX_PAGES=20
CULTURE_PORTAL_MAX_PAGES=30
KCISA_MAX_PAGES=100
KOPIS_MAX_PAGES=100
SEOUL_CULTURE_MAX_PAGES=10
EVENT_GEOCODE_MISS_BUDGET=50

# Event and culture data providers. Keep real keys out of Git.
CULTURE_PORTAL_API_KEY=your_culture_portal_api_key_or_leave_blank_to_reuse_public_data_key
KOPIS_API_KEY=your_kopis_api_key
KOPIS_BASE_URL=http://www.kopis.or.kr
KCISA_428_API_KEY=your_kcisa_428_api_key
KCISA_196_API_KEY=your_kcisa_196_api_key
KCISA_BASE_URL=https://api.kcisa.kr
