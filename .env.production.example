# 운영 배포용 예시입니다. 값은 CI/CD 또는 서버 secret store에서 주입하세요.
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

PARKING_PROVIDER_MODE=hybrid
DEFAULT_SEARCH_RADIUS_METERS=800
STALE_THRESHOLD_SECONDS=600
CACHE_TTL_SECONDS=45

KAKAO_REST_API_KEY=운영_카카오_REST_API_키
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com

SEOUL_OPEN_DATA_KEY=운영_서울_열린데이터광장_키
SEOUL_OPEN_DATA_BASE_URL=http://openapi.seoul.go.kr:8088

PUBLIC_DATA_SERVICE_KEY=운영_data.go.kr_서비스키
PUBLIC_DATA_ENV=production
PUBLIC_DATA_BASE_URL=https://apis.data.go.kr
