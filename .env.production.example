# Production deployment example. Inject real values through CI/CD or server secrets.
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

PARKING_PROVIDER_MODE=real
DEFAULT_SEARCH_RADIUS_METERS=800
DEFAULT_DISCOVER_RADIUS_METERS=20000
STALE_THRESHOLD_SECONDS=600
CACHE_TTL_SECONDS=45
DISCOVER_CACHE_TTL_SECONDS=21600

FESTIVAL_PROVIDER_ENABLED=true
EVENT_PROVIDER_ENABLED=true
LOCAL_EVENT_PROVIDER_ENABLED=true
LOCAL_EVENT_AUTO_APPROVE_MIN_SCORE=0.85
LOCAL_EVENT_SEARCH_MAX_QUERIES=24

NAVER_CLIENT_ID=production_naver_search_client_id
NAVER_CLIENT_SECRET=production_naver_search_client_secret
NAVER_SEARCH_BASE_URL=https://openapi.naver.com

KAKAO_REST_API_KEY=production_kakao_rest_api_key
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com

SEOUL_OPEN_DATA_KEY=production_seoul_open_data_key
SEOUL_OPEN_DATA_BASE_URL=http://openapi.seoul.go.kr:8088
SEOUL_SEONGDONG_IOT_KEY=production_seoul_seongdong_iot_key
SEOUL_HANGANG_PARKING_KEY=production_seoul_hangang_parking_key

PUBLIC_DATA_SERVICE_KEY=production_data_go_kr_service_key
PUBLIC_DATA_ENV=production
PUBLIC_DATA_BASE_URL=https://apis.data.go.kr

# Event and culture data providers. Inject real values through deployment secrets.
CULTURE_PORTAL_API_KEY=production_culture_portal_api_key_or_leave_blank_to_reuse_public_data_key
KOPIS_API_KEY=production_kopis_api_key
KOPIS_BASE_URL=http://www.kopis.or.kr
KCISA_428_API_KEY=production_kcisa_428_api_key
KCISA_196_API_KEY=production_kcisa_196_api_key
KCISA_BASE_URL=https://api.kcisa.kr
